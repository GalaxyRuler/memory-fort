{
  "name": "memory",
  "displayName": "Memory Fort",
  "description": "Capture VS Code chat turns into the local Memory Fort vault.",
  "version": "0.1.0",
  "publisher": "memory-fort",
  "license": "GPL-3.0-only",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onChatParticipant:memory-fort.memory",
    "onLanguage:*"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "memory-fort.memory",
        "name": "memory",
        "description": "Capture this chat turn into Memory Fort."
      }
    ]
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0"
  }
}
