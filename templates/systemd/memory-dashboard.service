[Unit]
Description=Memory dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=${INSTALL_ROOT}
ExecStart=${NODE_PATH} ${INSTALL_ROOT}/services/dashboard.mjs
Restart=on-failure
RestartSec=5
Environment=MEMORY_INSTALL_ROOT=${INSTALL_ROOT}
Environment=NODE_ENV=production
EnvironmentFile=-${INSTALL_ROOT}/env/voyage.env
StandardOutput=append:${INSTALL_ROOT}/logs/dashboard.log
StandardError=append:${INSTALL_ROOT}/logs/dashboard.log

[Install]
WantedBy=multi-user.target
